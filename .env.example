# .env.example
# pgdump-agent + postgres (Linux, docker-compose)

# ------------------------------------------------------------
# Agent HTTP server
# ------------------------------------------------------------

# Port the agent listens on inside the container
BACKUP_AGENT_PORT=1804

# REQUIRED for security in real deployments.
# If empty, agent will still run but requests are unauthenticated.
BACKUP_AGENT_TOKEN=change-me-long-random

# Directory inside container where dumps are written (mount a volume here)
BACKUP_TO_DIR=/backups

# How long pg_dump may run before being terminated (seconds)
# Default: 6000 (100 min)
BACKUP_TIMEOUT_SECONDS=6000

# Stale lock threshold (seconds). If lock timestamp is older than this, clear lock and retry.
# Default: BACKUP_TIMEOUT_SECONDS * 2
LOCK_STALE_SECONDS=

# Allow overriding DB connection variables via HTTP headers (NOT recommended)
ALLOW_ANY_DB=false


# ------------------------------------------------------------
# Retention policy (count-based)
# Used only when reason=daily|weekly|monthly
# ------------------------------------------------------------
BACKUP_KEEP_DAILY=30
BACKUP_KEEP_WEEKLY=12
BACKUP_KEEP_MONTHLY=12


# ------------------------------------------------------------
# Postgres connection (used by pg_dump)
#
# The agent runs INSIDE the same Postgres container by default,
# so host=127.0.0.1 works out of the box.
#
# Use the standard libpq PG* variables (recommended).
# ------------------------------------------------------------
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=postgres
PGUSER=postgres
PGPASSWORD=postgres
