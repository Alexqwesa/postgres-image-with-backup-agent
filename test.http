### Variables
@scheme = http
@host = 127.0.0.1
@port = 1804
@base = {{scheme}}://{{host}}:{{port}}
@token = REPLACE_WITH_YOUR_SECRET
# token currently unused
@timeout = 900

### Health check
GET {{base}}/health
Accept: application/json

> {%
client.test("health is OK", function() {
  client.assert(response.status === 200, "Expected 200");
  const body = (typeof response.body === 'string') ? JSON.parse(response.body) : response.body;
  client.assert(body.ok === true, "ok should be true");
});
%}

###

# -------- Daily backup --------
POST {{base}}/backup?reason=daily
Authorization: Bearer {{token}}
Content-Type: application/json
Accept: application/json

{}

> {%
client.test("daily backup accepted", function() {
  client.assert(response.status === 200, "Expected 200");
  const b = (typeof response.body === 'string') ? JSON.parse(response.body) : response.body;
  client.assert(b.ok === true, "ok should be true");
  client.assert(b.file && b.file.endsWith("_daily.dump"), "file should end with _daily.dump");
});
%}

###

